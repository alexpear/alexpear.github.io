{
  "name": "waffle",
  "version": "0.1.0",
  "description": "website + procedurally generated narrative + other fun scripts",
  "main": "WGenerator.js",
  "dependencies": {
    "boardgame.io": "^0.50.0",
    "browserify": "^17.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "comma-number": "^2.0.0",
    "d20": "^1.4.1",
    "geotiff": "^2.1.2",
    "hotkeys-js": "^3.4.3",
    "jest-transform-yaml": "^1.1.2",
    "js-yaml": "^4.1.0",
    "jsdom": "^24.1.0",
    "lodash": "^4.17.11",
    "masto": "^6.10.1",
    "moment": "^2.22.2",
    "phaser": "^3.16.2",
    "split": "^1.0.1",
    "webpack": "^5.43.0",
    "xml-stream": "^0.4.5"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^14.18.63",
    "babel-jest": "^30.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "3.3.3",
    "ts-jest": "^29.4.6",
    "typescript": "^4.9.5",
    "typescript-eslint": "^8.55.0",
    "webpack": "^5.24.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "ts-loader": "^9.0.0",
    "webpack-cli": "^4.5.0"
  },
  "scripts": {
    "start": "npm i && npm run buildAll",
    "firstTimeSetup": "npm install && npm install -g browserify && npm install -g http-server && npm start",
    "refresh": "npm run buildAll && npm run server",
    "buildAll": "npm run buildTreeBrowser && npm run buildFishTank && npm run buildGroupGrid && npm run buildTitleGen && npm run buildTextGen && npm run buildVillainverse && npm run buildWaffleCards && npm run whichgame && npm run whattowatch && npm run buildAI2027 && npm run buildawow && npm run buildPopGrid && npm run buildblockscout",
    "buildAllUnstable": "npm run buildTreeBrowser && npm run buildFishTank && npm run buildGroupGrid && npm run buildTitleGen && npm run buildTextGen",
    "buildTreeBrowser": "browserify treebrowser/treeBrowser.js -o treebrowser/bundle.js",
    "buildFishTank": "browserify fishTank/src/*.js -o fishTank/bundle.js",
    "buildGroupGrid": "browserify gridView/src/*.js bottleWorld/gridWarWorldState.js -o gridView/groupGridBundle.js",
    "buildTitleGen": "browserify titleGen/src/*.js -o titleGen/bundle.js",
    "buildTextGen": "browserify textGen/src/*.js -o textGen/bundle.js",
    "buildVillainverse": "browserify villainverse/src/*.js -o villainverse/bundle.js",
    "buildScifiWarband": "node scifiWarband/src/build/parser.js && browserify scifiWarband/src/*.js -o scifiWarband/bundle.js",
    "buildCleoCluster": "node cleoCluster/wikiWriter.js",
    "buildawow": "browserify warofwhispers/src/*.js -o warofwhispers/bundle.js",
    "buildPopGrid": "browserify generation/demographics/popGrid/src/*.js -o generation/demographics/popGrid/bundle.js",
    "buildWaffleCards": "node bottleWorld/waffleCards/src/build/parser.js && node bottleWorld/waffleCards/src/waffleCards.js",
    "waffleCards": "npm run buildWaffleCards && open bottleWorld/waffleCards/cardSet.html",
    "testwafflecards": "npm run buildWaffleCards",
    "whichgame": "browserify generation/mundane/whichgame/src/*.js -o generation/mundane/whichgame/bundle.js",
    "whattowatch": "browserify generation/mundane/whattowatch/src/*.js -o generation/mundane/whattowatch/bundle.js",
    "buildAI2027": "browserify pages/src/ai-2027.js -o pages/src/ai-2027.bundle.js",
    "gridWar": "npm run buildGroupGrid && npm run server",
    "server": "http-server",
    "cape": "node wnode/cape.js",
    "testOld": "jest",
    "test": "npm run lint && npm run prettierwrite && npm run buildblockscout && npm run buildspoilerfree && npm run history && npm run jest",
    "jest": "NODE_NO_WARNINGS=1 node --experimental-vm-modules node_modules/.bin/jest",
    "testAll": "npm run test && npm run testRingWorld && npm run testDeathPlanet",
    "lint": "eslint --cache games/**/*.ts intergame spoilerfree",
    "prettier": "prettier --check games/",
    "prettierwrite": "prettier --write games/ intergame/ pages/ spoilerfree/",
    "wgenerator": "node generation/wgenerator.js",
    "wkrieg": "node generation/wkriegArmy.js",
    "40k": "node generation/grimDarkArmy.js",
    "eclipse": "node wnode/spacebattles/vessel.js",
    "testDeathPlanet": "node bottleWorld/deathPlanetWorldState.js test",
    "testRingWorld": "node bottleWorld/ringWorldState.js test",
    "buildlimitless": "browserify bottleWorld/chronarchon/src/*.js --exclude bottleWorld/chronarchon/src/*.test.js -o bottleWorld/chronarchon/bundle.js && npm run server && open bottleWorld/chronarchon/chronarchon.html",
    "shelf": "node visuals/wildbow/shelf.js > visuals/wildbow/shelf.html && prettier --write visuals/wildbow/",
    "wots": "npm run lint && npm run prettierwrite && webpack --config games/wots/webpack.config.js &&  npm run jest && npm run server",
    "openwots": "open http://127.0.0.1:8083/games/wots/wots.html",
    "buildblockscout": "tsc -p games/blockscout && browserify games/blockscout/dist/blockscout.js -o games/blockscout/dist/bundle.js",
    "openblockscout": "npm run open games/blockscout/blockscout.html",
    "buildspoilerfree": "tsc -p spoilerfree/tsconfig.json && browserify spoilerfree/dist/*.js -o spoilerfree/bundle/spoilerfree.bundle.js",
    "history": "tsc -p pages/pophistory/tsconfig.json && browserify pages/pophistory/dist/popHistory.js -o pages/pophistory/dist/bundle.js",
    "intergame": "tsc -p intergame/tsconfig.json && npm run test && node intergame/dist/intergame.js",
    "intergamecsv": "tsc -p intergame/tsconfig.json && npm run test && node intergame/dist/mtg.js > intergame/data/mtg.csv; node intergame/dist/dnd5e.js > intergame/data/dnd5e.csv",
    "buildintergame": "tsc -p intergame/tsconfig.json && browserify intergame/dist/cardViewer.js -o intergame/dist/bundle.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexpear/alexpear.github.io.git"
  },
  "keywords": [
    "procedural",
    "generation",
    "narrative",
    "interactive",
    "fiction",
    "game",
    "tree",
    "graph",
    "random"
  ],
  "author": "Alex Pear",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/alexpear/alexpear.github.io/issues"
  },
  "homepage": "https://github.com/alexpear/alexpear.github.io#readme"
}
